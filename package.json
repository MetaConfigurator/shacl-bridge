{
  "name": "shacl-bridge",
  "version": "1.6.1",
  "description": "TypeScript library and CLI for parsing SHACL documents and transforming them into JSON Schema",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "shacl-bridge": "./dist/cli/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "prepare": "husky",
    "fix:lint-format": "npm run lint:fix && npm run format",
    "prepublishOnly": "npm run build && npm test",
    "benchmark": "npm run build && npm link && npx jiti benchmark/json-schema-to-shacl/run-benchmark.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MetaConfigurator/shacl-bridge.git"
  },
  "keywords": [
    "shacl",
    "rdf",
    "json-schema",
    "validation",
    "shapes",
    "semantic-web",
    "linked-data",
    "turtle",
    "n3",
    "json-ld"
  ],
  "author": "Giridhar C G <girigov39@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/MetaConfigurator/shacl-bridge/issues"
  },
  "homepage": "https://github.com/MetaConfigurator/shacl-bridge#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/jsonld": "^1.5.15",
    "@types/n3": "^1.26.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-junit": "^16.0.0",
    "jiti": "^2.6.1",
    "prettier": "3.8.1",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "@types/json-schema-merge-allof": "^0.6.5",
    "clipboardy": "^5.3.1",
    "commander": "^14.0.3",
    "json-schema-merge-allof": "^0.8.1",
    "jsonld": "^9.0.0",
    "n3": "^2.0.3",
    "pino": "^10.3.1",
    "rdf-canonize": "^5.0.0",
    "ts-pattern": "^5.9.0"
  }
}
