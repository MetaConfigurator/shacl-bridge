{
  "name": "shacl-bridge-benchmark",
  "version": "1.0.0",
  "description": "Standalone benchmark suite for shacl-bridge",
  "private": true,
  "scripts": {
    "setup": "npx jiti setup.ts",
    "benchmark": "npm run setup && npx jiti runner/run-benchmark.ts",
    "benchmark:roundtrip": "npm run setup && npx jiti runner/run-roundtrip-benchmark.ts",
    "benchmark:comake": "npx jiti runner/run-comake-benchmark.ts",
    "benchmark:siqueira": "npx jiti runner/run-siqueira-benchmark.ts",
    "benchmark:jsonschema2shacl": "npx jiti runner/run-jsonschema2shacl-benchmark.ts"
  },
  "dependencies": {
    "@comake/shacl-to-json-schema": "^1.0.3",
    "jsonld": "^8.3.3",
    "n3": "^1.23.1",
    "shacl-bridge": "latest",
    "shacl-jsonschema-converter": "^0.1.3"
  },
  "devDependencies": {
    "jiti": "^2.6.1"
  }
}
