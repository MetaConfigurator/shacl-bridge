@prefix sh:  <http://www.w3.org/ns/shacl#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix ex:  <http://example.org/>.

ex:NameShape
    a       sh:NodeShape ;
    sh:xone ( [ sh:property [ sh:path      ex:fullName ;
                              sh:datatype  xsd:string ;
                              sh:minLength 1 ;
                              sh:maxLength 50 ;
                              sh:minCount  1 ;
                              sh:maxCount  1 ] ] [ sh:property [ sh:path      ex:firstName ;
                                                                 sh:datatype  xsd:string ;
                                                                 sh:minLength 1 ;
                                                                 sh:maxLength 25 ;
                                                                 sh:minCount  1 ;
                                                                 sh:maxCount  1 ] ;
                                                   sh:property [ sh:path      ex:lastName ;
                                                                 sh:datatype  xsd:string ;
                                                                 sh:minLength 1 ;
                                                                 sh:maxLength 25 ;
                                                                 sh:minCount  1 ;
                                                                 sh:maxCount  1 ] ] ) .