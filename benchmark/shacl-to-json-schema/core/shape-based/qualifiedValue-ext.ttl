@prefix sh:  <http://www.w3.org/ns/shacl#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix ex:  <http://example.org/>.

ex:HandShape
    a              sh:NodeShape ;
    sh:targetClass ex:Hand ;
    sh:property    [ sh:path     ex:digit ;
                     sh:maxCount 5 ; ] ;
    sh:property    [ sh:path                         ex:digit ;
                     sh:qualifiedValueShape          [ sh:class ex:Thumb ] ;
                     sh:qualifiedValueShapesDisjoint true ;
                     sh:qualifiedMinCount            1 ;
                     sh:qualifiedMaxCount            1 ; ] ;
    sh:property    [ sh:path                         ex:digit ;
                     sh:qualifiedValueShape          [ sh:class ex:Finger ] ;
                     sh:qualifiedValueShapesDisjoint true ;
                     sh:qualifiedMinCount            4 ;
                     sh:qualifiedMaxCount            4 ; ] .

ex:QualifiedValueShapeExampleShape
    a           sh:NodeShape ;
    sh:property [ sh:path                ex:parent ;
                  sh:minCount            2 ;
                  sh:maxCount            2 ;
                  sh:qualifiedValueShape [ sh:path     ex:gender ;
                                           sh:hasValue ex:female ; ] ;
                  sh:qualifiedMinCount   1 ; ] .