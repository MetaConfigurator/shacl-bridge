@prefix sh:  <http://www.w3.org/ns/shacl#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix ex:  <http://example.org/>.

ex:PersonShape
    a              sh:NodeShape ;
    sh:targetClass ex:Person ;
    sh:property    [ sh:path     ex:employer ;
                     sh:minCount 1 ;
                     sh:maxCount 1 ;
                     sh:class    ex:Company ] .