@prefix ex:  <http://example.org/> .
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:FabricShape
    a           sh:PropertyShape ;
    sh:class    ex:Shirt ;
    sh:property [ sh:path ex:colour ;
                  sh:in   ( "Blue" "Green" "Black" "Red" "Yellow" ) ] .